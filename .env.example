# ─── Required ────────────────────────────────────────────────────────────────

# Your Anthropic API key (for CV parsing, fit scoring, cover letters)
# Get it at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your Notion Internal Integration Token
# Get it at: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_integration_token_here

# The ID of your Notion Job Tracker database
# Copy it from your database URL:
# https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=your_notion_database_id_here
